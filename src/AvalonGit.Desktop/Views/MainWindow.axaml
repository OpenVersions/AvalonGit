<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvalonGit.Desktop.ViewModels"
        xmlns:views="using:AvalonGit.Desktop.Views"
        xmlns:models="using:AvalonGit.Core.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="AvalonGit.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title=""
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="0"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="BorderOnly"
        CanResize="True"
        PointerPressed="Window_PointerPressed">

    <Window.Styles>
        <!-- MenuFlyoutPresenter Style -->
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="8,4,0,0"/>
        </Style>
        
        <!-- MenuItem Hover Style -->
        <Style Selector="MenuItem:pointerover /template/ Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#FFFFFFFF" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Separator Style -->
        <Style Selector="Separator">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Opacity" Value="0.1"/>
            <Setter Property="Margin" Value="8,4"/>
        </Style>
        <Style Selector="Path#MaximizeIcon">
            <Setter Property="Data" Value="{StaticResource IconMaximize}"/>
        </Style>
        <Style Selector="Window[WindowState=Normal] Border#MainAppFrame">
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="Window[WindowState=Maximized] Border#MainAppFrame">
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Window[WindowState=Maximized] Path#MaximizeIcon">
            <Setter Property="Data" Value="{StaticResource IconRestore}"/>
        </Style>
    </Window.Styles>

    <Border x:Name="MainAppFrame"
            Background="{DynamicResource BackgroundBrush}"
            ClipToBounds="True">
        <DockPanel>
            <!-- Top Bar: Menu + Window Buttons -->
            <Border DockPanel.Dock="Top" 
                    Background="{DynamicResource SurfaceBrush}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Hamburger Menu -->
                    <Button Grid.Column="0" Classes="titleBarButton" ToolTip.Tip="Menu">
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                <MenuItem Header="Abrir Repositório" Click="OpenRepository">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource IconFolder}" Foreground="{DynamicResource TextPrimaryBrush}" Width="28" Height="28" Margin="0,0,10,0"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Clonar Repositório" Command="{Binding CloneRepositoryCommand}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource IconClone}" Foreground="{DynamicResource TextPrimaryBrush}" Width="28" Height="28" Margin="0,0,10,0"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Novo Repositório">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource IconAdd}" Foreground="{DynamicResource TextPrimaryBrush}" Width="28" Height="28" Margin="0,0,10,0"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Preferências">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource IconSettings}" Foreground="{DynamicResource TextPrimaryBrush}" Width="28" Height="28" Margin="0,0,10,0"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Atalhos de Teclado">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource IconKeyboard}" Foreground="{DynamicResource TextPrimaryBrush}" Width="28" Height="28" Margin="0,0,10,0"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Verificar Atualizações">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource IconUpdate}" Foreground="{DynamicResource TextPrimaryBrush}" Width="28" Height="28" Margin="0,0,10,0"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Sobre" Click="OpenAboutWindow">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource IconInfo}" Foreground="{DynamicResource TextPrimaryBrush}" Width="28" Height="28" Margin="0,0,10,0"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Sair" Click="CloseWindow">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource IconExit}" Foreground="{DynamicResource TextPrimaryBrush}" Width="28" Height="28" Margin="0,0,10,0"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                        <Viewbox Width="16" Height="16" Stretch="Uniform">
                            <Path Data="{StaticResource IconHamburger}"
                                  Fill="{DynamicResource TextPrimaryBrush}"
                                  Classes="windowIcon"/>
                        </Viewbox>
                    </Button>
                    
                    <!-- Window Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0">
                        <Button Classes="titleBarButton"
                                Click="MinimizeWindow"
                                ToolTip.Tip="Minimizar">
                            <Viewbox Width="12" Height="12" Stretch="Uniform">
                                <Path Data="{StaticResource IconMinimize}" Classes="windowIcon"/>
                            </Viewbox>
                        </Button>
                        <Button Classes="titleBarButton"
                                Click="MaximizeWindow"
                                ToolTip.Tip="Maximizar"
                                x:Name="MaximizeButton">
                            <Viewbox Width="12" Height="12" Stretch="Uniform">
                                <Path Classes="windowIcon"
                                      x:Name="MaximizeIcon"/>
                            </Viewbox>
                        </Button>
                        <Button Classes="titleBarButton closeButton"
                                Click="CloseWindow"
                                ToolTip.Tip="Fechar">
                            <Viewbox Width="12" Height="12" Stretch="Uniform">
                                <Path Data="{StaticResource IconClose}" Classes="windowIcon"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid ColumnDefinitions="300, *">
                <!-- Sidebar: Changes -->
                <Border Grid.Column="0" 
                        Background="{DynamicResource SurfaceBrush}" 
                        BorderBrush="{DynamicResource BackgroundBrush}" 
                        BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto, *, Auto, *, Auto">
                        <!-- Unstaged Files -->
                        <TextBlock Grid.Row="0" Text="ALTERAÇÕES (UNSTAGED)" 
                                    Margin="10,10,10,5" FontSize="11" FontWeight="Bold" 
                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                        
                        <ListBox Grid.Row="1" ItemsSource="{Binding UnstagedFiles}" 
                                 SelectedItem="{Binding SelectedUnstagedFile}"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Text="{Binding FilePath}" 
                                                   VerticalAlignment="Center" 
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1" 
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).StageFileCommand}" 
                                                CommandParameter="{Binding FilePath}"
                                                Classes="titleBarButton" Padding="4">
                                            <PathIcon Data="{StaticResource IconAdd}" Width="12" Height="12"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Staged Files -->
                        <TextBlock Grid.Row="2" Text="STAGED" 
                                    Margin="10,10,10,5" FontSize="11" FontWeight="Bold" 
                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                        
                        <ListBox Grid.Row="3" ItemsSource="{Binding StagedFiles}" 
                                 SelectedItem="{Binding SelectedStagedFile}"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Text="{Binding FilePath}" 
                                                   VerticalAlignment="Center" 
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1" 
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).UnstageFileCommand}" 
                                                CommandParameter="{Binding FilePath}"
                                                Classes="titleBarButton" Padding="4">
                                            <PathIcon Data="{StaticResource IconMinimize}" Width="12" Height="12"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Commit Area -->
                        <StackPanel Grid.Row="4" Margin="10" Spacing="8">
                            <TextBox Text="{Binding CommitMessage}"
                                     Watermark="Mensagem do commit..."
                                     AcceptsReturn="True"
                                     MinHeight="60"
                                     MaxHeight="100"/>
                            <Button Content="Commit"
                                    Command="{Binding CommitCommand}"
                                    HorizontalAlignment="Stretch"
                                    Classes="titleBarButton"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Editor / Content Area -->
                <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
                    <Panel>
                        <!-- Welcome Message (Visible when no file selected) -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10"
                                    IsVisible="{Binding !DiffLines.Count}">
                            <TextBlock Text="{Binding Greeting}" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="24"
                                       IsVisible="{Binding !IsLoadingDiff}"/>
                            <TextBlock Text="{Binding RepositoryPath}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Loading Indicator -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10"
                                    IsVisible="{Binding IsLoadingDiff}">
                            <ProgressBar IsIndeterminate="True" Width="200" Height="2"
                                         Foreground="{DynamicResource AccentBrush}"
                                         Background="Transparent"/>
                            <TextBlock Text="Analisando mudanças..." 
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       FontSize="12"/>
                        </StackPanel>

                        <!-- Diff Viewer -->
                        <ListBox ItemsSource="{Binding DiffLines}"
                                 IsVisible="{Binding !IsLoadingDiff}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                </Style>
                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                                
                                <Style Selector="Grid.Addition">
                                    <Setter Property="Background" Value="{DynamicResource DiffAddedBackground}"/>
                                </Style>
                                <Style Selector="Grid.Deletion">
                                    <Setter Property="Background" Value="{DynamicResource DiffRemovedBackground}"/>
                                </Style>
                                <Style Selector="Grid.Header">
                                    <Setter Property="Background" Value="{DynamicResource DiffHeaderBackground}"/>
                                </Style>
                                
                                <Style Selector="Grid.Addition TextBlock.CodeContent">
                                    <Setter Property="Foreground" Value="{DynamicResource DiffAddedForeground}"/>
                                </Style>
                                <Style Selector="Grid.Deletion TextBlock.CodeContent">
                                    <Setter Property="Foreground" Value="{DynamicResource DiffRemovedForeground}"/>
                                </Style>
                                <Style Selector="Grid.Header TextBlock.CodeContent">
                                    <Setter Property="Foreground" Value="{DynamicResource DiffHeaderForeground}"/>
                                </Style>
                                <Style Selector="Grid.Info TextBlock.CodeContent">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter Property="FontStyle" Value="Italic"/>
                                    <Setter Property="Opacity" Value="0.6"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:DiffLine">
                                    <Grid ColumnDefinitions="45,45,20,*" 
                                          Classes.Context="{Binding Type, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:DiffLineType.Context}}"
                                          Classes.Addition="{Binding Type, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:DiffLineType.Addition}}"
                                          Classes.Deletion="{Binding Type, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:DiffLineType.Deletion}}"
                                          Classes.Header="{Binding Type, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:DiffLineType.Header}}"
                                          Classes.Info="{Binding Type, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:DiffLineType.Info}}">
                                        
                                        <!-- Gutter Background -->
                                        <Border Grid.Column="0" Grid.ColumnSpan="2" 
                                                Background="{DynamicResource DiffGutterBackground}" 
                                                BorderBrush="{DynamicResource SurfaceBrush}" 
                                                BorderThickness="0,0,1,0"/>
                                        
                                        <!-- Line Numbers -->
                                        <TextBlock Grid.Column="0" Text="{Binding OldLineNumber}" 
                                                   Foreground="{DynamicResource DiffGutterForeground}"
                                                   FontFamily="Cascadia Code, JetBrains Mono, Consolas, Monospace"
                                                   FontSize="11" Margin="0,0,5,0" 
                                                   TextAlignment="Right" VerticalAlignment="Center"/>
                                        
                                        <TextBlock Grid.Column="1" Text="{Binding NewLineNumber}" 
                                                   Foreground="{DynamicResource DiffGutterForeground}"
                                                   FontFamily="Cascadia Code, JetBrains Mono, Consolas, Monospace"
                                                   FontSize="11" Margin="0,0,5,0" 
                                                   TextAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- Indicator -->
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" 
                                                   HorizontalAlignment="Center"
                                                   FontFamily="Cascadia Code, JetBrains Mono, Consolas, Monospace"
                                                   FontSize="12" Opacity="0.6"
                                                   Foreground="{DynamicResource DiffIndicatorForeground}">
                                            <TextBlock.Styles>
                                                <Style Selector="TextBlock">
                                                    <Setter Property="Text" Value=""/>
                                                </Style>
                                                <Style Selector="Grid.Addition TextBlock">
                                                    <Setter Property="Text" Value="+"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource DiffAddedForeground}"/>
                                                </Style>
                                                <Style Selector="Grid.Deletion TextBlock">
                                                    <Setter Property="Text" Value="-"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource DiffRemovedForeground}"/>
                                                </Style>
                                            </TextBlock.Styles>
                                        </TextBlock>

                                        <!-- Code -->
                                        <SelectableTextBlock Grid.Column="3" Text="{Binding Content}"
                                                           Classes="CodeContent"
                                                           FontFamily="Cascadia Code, JetBrains Mono, Consolas, Monospace"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Padding="10,0"
                                                           TextWrapping="NoWrap"
                                                           VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Panel>
                </Border>
            </Grid>

            <!-- Footer: Status Bar -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource SurfaceBrush}"
                    Padding="10,6">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Branch:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentBranch}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                        <Button Content="Push"
                                Command="{Binding PushCommand}"
                                Classes="titleBarButton"
                                IsEnabled="{Binding !IsPushing}"/>
                        <Button Content="+"
                                Classes="titleBarButton"
                                ToolTip.Tip="Adicionar Remote"
                                Command="{Binding AddRemoteCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toast Panel -->
            <views:ToastPanel Grid.Column="1" Grid.Row="1"
                              VerticalAlignment="Bottom"
                              HorizontalAlignment="Right"
                              DataContext="{Binding Toast}"/>

            <!-- Error Details Panel -->
            <Border Grid.Column="1" Grid.Row="1"
                    Background="{DynamicResource SurfaceBrush}"
                    Padding="16"
                    Margin="16"
                    CornerRadius="8"
                    IsVisible="{Binding ShowErrorDetails}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="600">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="Detalhes do Erro"
                               FontWeight="Bold" FontSize="16"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,10"/>
                    <ScrollViewer Grid.Row="1" MaxHeight="200">
                        <TextBox Text="{Binding ErrorLog}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 FontSize="12"/>
                    </ScrollViewer>
                    <Button Grid.Row="2" Content="Fechar"
                            Classes="titleBarButton"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0"
                            Click="CloseErrorPanel"/>
                </Grid>
            </Border>
        </DockPanel>
    </Border>

</Window>